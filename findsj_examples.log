. which getiref
/Users/ronald/Desktop/paper/statajournal/findsj/getiref.ado
*! version 2.3  2025/05/08
*! version 1.1 2023/9/26
*! Yujun Lian, arlionn@163.com

.
. * Verify that an author command returns exactly the records whose author field
. * contains every query term as a complete name token.
. capture program drop verify_author_count

. program define verify_author_count
  1.     version 16
  2.     syntax, Query(string) Returned(integer)
  3.
.     preserve
  4.     quietly use "findsj.dta", clear
  5.     capture confirm variable authors
  6.     if !_rc rename authors author
  7.
.     tempvar author_tokens matched
  8.     quietly gen strL `author_tokens' = ustrlower(author)
  9.     quietly replace `author_tokens' = ///
>         ustrregexra(`author_tokens', "[^\p{L}\p{N}_]+", " ")
 10.     quietly replace `author_tokens' = ///
>         " " + strtrim(stritrim(`author_tokens')) + " "
 11.
.     local query_clean = ///
>         ustrlower(ustrregexra(`"`query'"', "[^\p{L}\p{N}_]+", " "))
 12.     local query_clean = strtrim(stritrim(`"`query_clean'"'))
 13.     local n_words = wordcount(`"`query_clean'"')
 14.
.     quietly gen byte `matched' = 1
 15.     forvalues i = 1/`n_words' {
 16.         local query_word = word(`"`query_clean'"', `i')
 17.         quietly replace `matched' = 0 if ///
>             strpos(`author_tokens', " `query_word' ") == 0
 18.     }
 19.
.     quietly count if `matched'
 20.     local expected = r(N)
 21.     restore
 22.
.     if `returned' != `expected' {
 23.         display as error "Author-search regression test failed for: `query'
> "
 24.         display as error "Command returned `returned'; expected `expected'.
> "
 25.         exit 9
 26.     }
 27.     display as result ///
>         "PASS: `query' returned all `returned' complete-token matches."
 28. end

.
.
