. return list

scalars:
          r(n_results) =  71

macros:
              r(url_1) : "https://www.stata-journal.com/article.html?article=st0791"
              r(doi_1) : "."
           r(author_1) : "G. De Luca and J. R. Magnus."
            r(title_1) : "Weighted-average least squares:  Beyond the classical linear regression model"
           r(art_id_1) : "st0791"
                r(url) : "https://www.stata-journal.com/sjsearch.html?choice=keyword&q=panel+data"
              r(scope) : "keyword"
           r(keywords) : "panel data"

. 
. * Return values include:
. * r(keywords)   - Search keywords used
. * r(scope)      - Search scope (author/title/keyword)
. * r(url)        - Full search URL on Stata Journal website
. * r(n_results)  - Total number of articles found
. * r(art_id_1)   - Article ID of first result
. * r(title_1)    - Title of first result  
. * r(author_1)   - Author of first result
. * r(doi_1)      - DOI of first result (if available)
. * r(url_1)      - Article URL of first result
. 
